# ═══════════════════════════════════════════════════════════════
#  AXIGRADE SCRIPT GENERATOR — Environment Configuration
# ═══════════════════════════════════════════════════════════════

# ── AI Provider API Keys ──────────────────────────────────────
GOOGLE_API_KEY=your_gemini_key_here
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── Global Fallback ───────────────────────────────────────────
# Used when no task-specific model is set.
# Options: gemini | openai | claude
DEFAULT_MODEL=gemini

# ── Per-Task: Which Provider ──────────────────────────────────
# Options: gemini | openai | claude
TREND_HUNTER_MODEL=gemini
SCRIPT_WRITER_MODEL=gemini
PRODUCER_MODEL=gemini

# ── Per-Task: Which Exact Model ───────────────────────────────
# Overrides the provider-level default for that specific task.
# If not set, falls back to the provider global below.
#
# Gemini options:  gemini-2.0-flash | gemini-2.0-flash-lite | gemini-1.5-pro
# OpenAI options:  gpt-4o | gpt-4o-mini | o3 | o3-mini | o1
# Claude options:  claude-opus-4-5 | claude-sonnet-4-5 | claude-haiku-4-5-20251001
#
TREND_HUNTER_MODEL_NAME=gemini-2.0-flash
SCRIPT_WRITER_MODEL_NAME=gemini-2.0-flash
PRODUCER_MODEL_NAME=gemini-2.0-flash

# ── Provider-Level Global Defaults ───────────────────────────
# Used when a task has no _MODEL_NAME override.
GEMINI_MODEL=gemini-2.0-flash
OPENAI_MODEL=gpt-4o
CLAUDE_MODEL=claude-opus-4-5

# ── Browse / Deep Web Research (feature-flagged) ─────
# Set ENABLE_BROWSE=true ONLY when you are ready to activate it.
# The endpoint takes a search query and returns multi-site research results.
# WARNING: This can take 12-15 minutes per request — pipeline waits for it.
ENABLE_BROWSE=false
BROWSE_ENDPOINT_URL=https://your-browse-endpoint.com/search
BROWSE_TIMEOUT_SECONDS=900────────
YOUTUBE_API_KEY=your_youtube_data_api_key_here

# ── Serper (Google News trends) ───────────────────────────────
SERPER_API_KEY=your_serper_api_key_here

# ── Cloudinary (PDF hosting) ──────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
-e 
# MongoDB
MONGODB_URI=mongodb://localhost:27017/
